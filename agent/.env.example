# The Pit Boss — agent / keeper config (Robinhood Chain testnet)
# Copy to .env and fill in. NEVER commit real keys.

# Keeper + boss wallet (signs price reports, counter-drafts, settles)
PRIVATE_KEY=0x...
RELAY_SIGNER=0x...        # address derived from PRIVATE_KEY (relay report signer)
BOSS_ADDRESS=0x...        # boss wallet address

# Optional demo player (for self-play / harness)
PLAYER_KEY=0x...
PLAYER=0x...

ROBINHOOD_RPC=https://rpc.testnet.chain.robinhood.com

# Active v4 deployment (defaults baked into config; override here if redeployed)
RELAY=0xA8799b40d1BD22CfD23AEf49561B41A156C64622
BATTLE=0xDe530201016Cad12DE4dE169885E4576526832F7
VAULT=0x83FE2617202FC720A50E3e194596c99861B84BBE
CRYPTO_RELAY=0xbe1DCb3FBfDefd0962801a77e534C97F6468e4af
CRYPTO_BATTLE=0xf22F98fACbF7e1020F6EF6B386dF17d57C82827C

# Override the 24/5 market-hours guard for weekend demos
FORCE_MARKET_OPEN=true

# Crypto price source (Alchemy Prices API, free tier — alchemy.com)
ALCHEMY_API_KEY=
